# ── Loyverse ────────────────────────────────────────────────────────────────
LOYVERSE_TOKEN=tu_token_de_loyverse_aqui
LOYVERSE_BASE_URL=https://api.loyverse.com/v1.0

# ── Hacienda / CRlibre ──────────────────────────────────────────────────────
HACIENDA_USER=tu_cedula@hacienda.go.cr
HACIENDA_PASSWORD=tu_password_hacienda
HACIENDA_PIN=pin_del_certificado
CERT_PATH=./certificado.p12

# ── Datos del emisor ────────────────────────────────────────────────────────
EMISOR_CEDULA=3101123456
EMISOR_NOMBRE=Mi Empresa S.A.
EMISOR_ACTIVIDAD=620100
EMISOR_EMAIL=facturacion@miempresa.com
EMISOR_TELEFONO=22001234
EMISOR_PROVINCIA=1
EMISOR_CANTON=01
EMISOR_DISTRITO=01

# ── Sistema ─────────────────────────────────────────────────────────────────
# Cambiar a "produccion" para el ambiente real de Hacienda
AMBIENTE=sandbox

# Cambiar a "false" cuando las credenciales reales estén configuradas.
# Controla AMBOS sistemas a la vez salvo que se definan los flags granulares abajo.
USE_MOCK=true

# Flags granulares (opcionales). Si no se definen, heredan el valor de USE_MOCK.
# Permiten conectar Loyverse real SIN activar el envío a Hacienda:
#   USE_MOCK_LOYVERSE=false  -> lee ventas reales de Loyverse
#   USE_MOCK_HACIENDA=true   -> Hacienda sigue simulado (no emite nada real)
# USE_MOCK_LOYVERSE=true
# USE_MOCK_HACIENDA=true

# Tipo de comprobante: 01=Factura Electrónica, 04=Tiquete Electrónico
TIPO_COMPROBANTE=04

MONEDA=CRC
DATABASE_PATH=./database/facturas.db
XML_OUTPUT_DIR=./xml_output
LOG_DIR=./logs
LOG_LEVEL=INFO
MAX_RETRIES=3
RETRY_DELAY_SECONDS=10
